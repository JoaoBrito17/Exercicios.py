#11. Leia um número e: Se for par e positivo → “Par positivo”; Se for par e negativo → “Par
#negativo”; Caso contrário → “Ímpar”

numero = int(input("digite um numero:"))
print(numero)
if numero % 2 == 0 and numero > 0:
    print("Par positivo")
if numero % 2 == 0 and numero < 0:
    print("Par negativo")
else:
    print("impar")
